generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MerchantStatus {
  active
  inactive
}

enum TransactionType {
  payin
  payout
}

enum Currency {
  GTQ
  COP
  USD
}

enum TransactionStatus {
  pending
  approved
  rejected
  failed
  completed
}

enum SettlementStatus {
  pending
  processed
  paid
}

model Merchant {
  id String @id @default(uuid())
  name      String
  email     String   @unique
  apiKey    String   @unique @map("api_key")
  status    MerchantStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]

  @@map("merchants")
}

model Transaction {
 id String @id @default(uuid())
  merchantId  String            @map("merchant_id")
  amount      Decimal           @db.Decimal(12, 2)
  currency    Currency
  type        TransactionType
  status      TransactionStatus @default(pending)
  reference   String            @unique
  metadata    Json?

  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  merchant    Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  settlementTransactions SettlementTransaction[]

  @@index([merchantId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Settlement {
  id String @id @default(uuid())
  merchantId        String   @map("merchant_id")
  totalAmount       Decimal  @db.Decimal(14, 2) @map("total_amount")
  transactionCount  Int      @map("transaction_count")
  status            SettlementStatus @default(pending)
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  createdAt         DateTime @default(now()) @map("created_at")

  merchant               Merchant               @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  settlementTransactions SettlementTransaction[]

  @@index([merchantId])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("settlements")
}

model SettlementTransaction {
  settlementId  String @map("settlement_id")
  transactionId String @unique @map("transaction_id")

  settlement    Settlement  @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@id([settlementId, transactionId])
  @@map("settlement_transactions")
}